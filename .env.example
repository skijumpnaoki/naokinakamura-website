# Base URL of the Flying Report public API (no trailing slash).
# The /api/news serverless proxy appends "/api/public/posts?lang=..." to this.
# While the upstream endpoint is unpublished, the proxy automatically serves mock
# data, so the site works without this being set. Point it at the live host to
# switch to real data — no code change required.
#
# Local dev with `vercel dev` reads this from .env.local (copy this file).
FLYING_REPORT_API_BASE=https://flying-report-manager.vercel.app
